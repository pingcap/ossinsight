{
  "name": "@ossinsight/background",
  "version": "0.0.1",
  "description": "Shared Orbital task scheduler service for OSS Insight",
  "license": "Apache-2.0",
  "author": "OSS Insight Team",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tasks": {
      "import": "./dist/tasks/index.js",
      "types": "./dist/tasks/index.d.ts"
    }
  },
  "bin": {
    "background-service": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mini256/orbital": "^0.1.0",
    "dotenv": "^16.0.0",
    "pino": "^8.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
